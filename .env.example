# ──────────────────────────────────────────────────────────────────────────
# ArticleWriterPro — OPTIONAL environment configuration
#
# The app runs with safe defaults and requires NO .env file ("zero-env" mode).
# Complete the First-Run Setup Wizard in the browser to configure the admin
# account and AI provider — do NOT put real API keys here unless you understand
# the security trade-offs.
#
# Copy to `.env` only if you need advanced/manual configuration.
# NEVER commit a real `.env` or real secrets to version control.
# ──────────────────────────────────────────────────────────────────────────

# Runtime environment: development | production
NODE_ENV=production

# Port the server listens on.
PORT=3001

# Persistent, writable data directory. Database, app-secret and uploads live
# here. Defaults to ./data (=> /app/data inside the Docker image).
# DATA_DIR=/app/data

# Optional: override the auto-generated app secret used to sign sessions and
# encrypt stored secrets. If unset, a random secret is generated and persisted
# at <DATA_DIR>/app-secret. Must be at least 16 characters.
# APP_SECRET=

# CORS allowlist (comma-separated origins). Leave empty when the SPA is served
# from the same origin as the API (the default for the bundled image).
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Maximum request body size.
# BODY_LIMIT=2mb

# Rate limiting.
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=1000
# AUTH_RATE_LIMIT_MAX=30

# Set to "false" if NOT running behind a reverse proxy (Railway/Easypanel/Nginx).
# TRUST_PROXY=true
